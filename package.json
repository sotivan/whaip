{
  "name": "whaip",
  "version": "0.1.0",
  "description": "AI-powered desktop browser with voice, hand gesture, and vision control",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": ["browser", "ai", "voice", "vision", "electron"],
  "author": "WHAIP Team",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "ws": "^8.16.0",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.whaip.app",
    "productName": "WHAIP",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "extraResources": [
      {
        "from": "agent/",
        "to": "agent/"
      },
      {
        "from": "whaip.config.yaml",
        "to": "whaip.config.yaml"
      }
    ]
  }
}
